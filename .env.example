# ─────────────────────────────────────────────────────────────────────────────
# FAOS Next.js Template — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in the values for your environment.
# NEVER commit .env.local to source control.
#
# All variables are validated by Zod at startup (src/shared/lib/env.ts).
# The app will throw a descriptive error if a required variable is missing.
# ─────────────────────────────────────────────────────────────────────────────

# ── API ───────────────────────────────────────────────────────────────────────
# Base URL of your backend REST API. Required.
# Example: http://localhost:3001 (local dev) | https://api.yourapp.com (prod)
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Site ──────────────────────────────────────────────────────────────────────
# Canonical public URL of this frontend. Used for OG tags and sitemap.ts.
# Optional in development, required in production.
# Example: https://yourapp.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── App Environment ───────────────────────────────────────────────────────────
# Drives feature flag defaults and logging behavior.
# Must be one of: development | staging | production
NEXT_PUBLIC_APP_ENV=development
